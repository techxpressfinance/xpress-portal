# Database
DATABASE_URL=sqlite:///./app.db

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
UPLOAD_DIR=./uploads

# OCR Engine: "easyocr" or "tesseract"
OCR_ENGINE=tesseract

# Email (SMTP) - Optional, notifications disabled if not set
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# OneDrive via Power Automate - Optional
POWER_AUTOMATE_WEBHOOK_URL=
ONEDRIVE_BASE_FOLDER=XpressTech

# Lend.com.au API - Optional
LEND_API_KEY=
LEND_API_SECRET=
LEND_ENVIRONMENT=sandbox

# Environment
ENVIRONMENT=development
