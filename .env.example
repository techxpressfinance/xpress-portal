# =============================================================================
# Xpress Tech Portal — Environment Variables
# Copy to .env (root) for Docker Compose, or backend/.env for native deploy
# =============================================================================

# --- Core ---
ENVIRONMENT=production                    # development | production
DATABASE_URL=postgresql://xpresstech:changeme@localhost:5432/xpresstech
JWT_SECRET_KEY=change-me-to-a-strong-random-string
UPLOAD_DIR=./uploads

# --- PII Encryption (REQUIRED in production) ---
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# --- CORS ---
CORS_ORIGINS=https://yourdomain.com      # Comma-separated allowed origins

# --- S3 Storage (optional — falls back to local filesystem) ---
S3_BUCKET_NAME=
S3_REGION=ap-southeast-2

# --- OCR Engine ---
OCR_ENGINE=tesseract                      # tesseract (lightweight) | easyocr (GPU-friendly)

# --- Email / SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=tech@xpressfinance.com.au

# --- Email Verification ---
EMAIL_VERIFICATION_EXPIRE_HOURS=24
FRONTEND_URL=https://yourdomain.com

# --- OpenAI / LLM Analysis (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- OneDrive via Power Automate (optional) ---
POWER_AUTOMATE_WEBHOOK_URL=
ONEDRIVE_BASE_FOLDER=XpressTech

# --- Lend.com.au API (optional) ---
LEND_API_KEY=
LEND_API_SECRET=
LEND_ENVIRONMENT=sandbox

# --- Backups (optional) ---
S3_BACKUP_BUCKET=
